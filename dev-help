#!/usr/bin/env zsh

gum style \
    --foreground 2 --border rounded --padding "1 2" \
    "🛠️ Dev Help"

echo ""
gum style --foreground 3 "Comandos disponibles:"
echo ""
echo "  🍃 spring-new      Crear nuevo proyecto Spring Boot"
echo "  📂 dev-project     Seleccionar y abrir un proyecto"
echo "  📊 repo-status     Ver estado del repositorio"
echo "  📝 git-commit      Hacer commit interactivo"
echo "  🚀 git-push        Pushear commits pendientes"
echo "  🐘 gradle-run      Ejecutar tasks de Gradle"
echo "  🐳 docker-start    Iniciar Docker y Lazydocker"
echo ""

gum confirm "¿Quieres ejecutar algún comando?" || exit 0

echo ""

OPCION=$(gum choose \
    "🍃 spring-new" \
    "📂 dev-project" \
    "📊 repo-status" \
    "📝 git-commit" \
    "🚀 git-push" \
    "🐘 gradle-run" \
    "🐳 docker-start" \
    --header "¿Qué ejecutamos?")

case $OPCION in
    "🍃 spring-new") spring-new ;;
    "📂 dev-project") dev-project ;;
    "📊 repo-status") repo-status ;;
    "📝 git-commit") git-commit ;;
    "🚀 git-push") git-push ;;
    "🐘 gradle-run") gradle-run ;;
    "🐳 docker-start") docker-start ;;
esac
