#!/usr/bin/env zsh

PROJECT=$(ls ~/projects | gum filter --header "🚀 ¿Qué proyecto abrir?")

if [ -z "$PROJECT" ]; then
    gum style --foreground 1 "✗ No seleccionaste ningún proyecto"
    exit 0
fi

ACCION=$(gum choose "Abrir con Neovim" "Solo navegar a la carpeta" --header "📁 $PROJECT")

case $ACCION in
    "Abrir con Neovim")
        cd ~/projects/$PROJECT && nvim .
        ;;
    "Solo navegar a la carpeta")
        cd ~/projects/$PROJECT
        gum style --foreground 2 "✓ Estás en ~/projects/$PROJECT"
        ;;
esac
