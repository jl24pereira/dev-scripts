#!/usr/bin/env zsh

gum style \
    --foreground 2 --border rounded --padding "1 2" \
    "🐘 Gradle Runner"

# Buscar build.gradle en el directorio actual o subdirectorios
BUILD_FILE=$(find . -name "build.gradle" -o -name "build.gradle.kts" 2>/dev/null | head -1)

if [ -z "$BUILD_FILE" ]; then
    gum style --foreground 1 "✗ No se encontró build.gradle en el proyecto"
    exit 1
fi

# Dar permisos y definir comando
if [ -f "./gradlew" ]; then
    chmod +x ./gradlew
    GRADLE_CMD="./gradlew"
else
    GRADLE_CMD="gradle"
fi

# Seleccionar task
TASK=$(gum choose \
    "build" \
    "clean" \
    "clean build" \
    "bootRun" \
    "test" \
    "clean test" \
    --header "🔧 Selecciona la task de Gradle")

if [ -z "$TASK" ]; then
    gum style --foreground 1 "✗ No seleccionaste ninguna task"
    exit 0
fi

gum style --foreground 3 "⚙️  Ejecutando: gradle $TASK"
echo ""

# Ejecutar task — pasar como array para manejar múltiples tasks
if [ "$TASK" = "bootRun" ]; then
    $GRADLE_CMD ${=TASK}
else
    $GRADLE_CMD ${=TASK} 2>&1 | tee /tmp/gradle-output.log
    EXIT_CODE=${pipestatus[1]}

    if [ $EXIT_CODE -eq 0 ]; then
        gum style --foreground 2 "✓ gradle $TASK completado exitosamente"
    else
        gum style --foreground 1 "✗ gradle $TASK falló"
    fi

    echo ""
    gum confirm "¿Ver logs completos?" && gum pager < /tmp/gradle-output.log
fi
